---
const career = [
  { year: '2021', text: '東証プライム上場 金融会社 M&A戦略部 入社' },
  { year: '2022', text: 'WEBデザイナーとして独立' },
  { year: '2023', text: '都内マーケティング事務所でチームアップ、WEBディレクターとして活動開始' },
  { year: '2025', text: '東証プライム上場 インフラ会社 資本戦略部へ' },
  { year: '現在', text: '複業として地域の中小企業デジタル支援を継続中' },
];

const skills = [
  { category: '経営・財務', items: ['財務分析', '経営評価', '海外ビジネス', 'M&A実務'] },
  { category: 'WEB', items: ['Wix', 'WordPress', 'STUDIO'] },
  { category: 'EC', items: ['Shopify', 'Stores', 'BASE'] },
  { category: '予約・OTA', items: ['Airbnb', 'Booking.com', '楽天トラベル', '一休'] },
  { category: '決済・LINE', items: ['Stripe', 'KOMOJU', 'LINE公式'] },
  { category: 'AI・業務改善', items: ['業務フロー設計', '自動化支援'] },
];
---
<section class="about" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-left">
        <span class="section-label">About</span>
        <h2 class="section-title">プロフィール</h2>
        <div class="about-avatar">
          <div class="avatar-circle">
            <span>YU</span>
          </div>
        </div>
        <p class="about-name">YU_TABI</p>
        <p class="about-role">WEBディレクター / 複業</p>
        <p class="about-text">
          東証プライム上場企業の資本戦略部に勤務しながら、中小企業のデジタル支援を複業で行っています。
          本業で培った経営・財務・海外ビジネスの視点をデジタル支援に活かし、
          地域の事業者が全国・世界に届く土台をつくることを目指しています。
        </p>
      </div>

      <div class="about-right">
        <div class="career-block">
          <h3 class="block-heading">キャリア</h3>
          <div class="career-list">
            {career.map((c) => (
              <div class="career-item">
                <span class="career-year">{c.year}</span>
                <span class="career-text" set:html={c.text} />
              </div>
            ))}
          </div>
        </div>

        <div class="skills-block">
          <h3 class="block-heading">スキル・対応ツール</h3>
          <div class="skills-grid">
            {skills.map((s) => (
              <div class="skill-group">
                <p class="skill-category">{s.category}</p>
                <div class="skill-items">
                  {s.items.map((item) => (
                    <span class="skill-tag">{item}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.about-grid {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 80px;
  align-items: start;
}

.about-avatar {
  margin-bottom: 16px;
}

.avatar-circle {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: var(--accent-light);
  border: 3px solid var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--accent);
}

.about-name {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4px;
}

.about-role {
  font-size: 0.875rem;
  color: var(--text-muted);
  margin-bottom: 20px;
}

.about-text {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.95;
}

.block-heading {
  font-family: var(--font-serif);
  font-size: 1rem;
  font-weight: 600;
  color: var(--text);
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 20px;
}

.career-block {
  margin-bottom: 48px;
}

.career-list {
  display: flex;
  flex-direction: column;
}

.career-item {
  display: grid;
  grid-template-columns: 72px 1fr;
  gap: 16px;
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
  align-items: baseline;
}

.career-year {
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--accent);
  font-family: var(--font-serif);
}

.career-text {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.7;
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

.skill-category {
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--text-muted);
  letter-spacing: 0.05em;
  margin-bottom: 8px;
}

.skill-items {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.skill-tag {
  font-size: 0.75rem;
  background: var(--bg-alt);
  color: var(--text);
  padding: 4px 10px;
  border-radius: 4px;
  border: 1px solid var(--border);
}

@media (max-width: 1024px) {
  .about-grid {
    grid-template-columns: 1fr;
    gap: 48px;
  }
}

@media (max-width: 640px) {
  .skills-grid {
    grid-template-columns: 1fr;
  }
}
</style>
