<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo">YU_TABI</a>
        <p class="footer-tagline">地域とつなぐ、世界とつなぐ。</p>
      </div>
      <nav class="footer-nav">
        <a href="#philosophy">Philosophy</a>
        <a href="#services">Services</a>
        <a href="#works">Works</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <p class="copyright">© 2026 YU_TABI. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--text);
  color: var(--white);
  padding: 48px 0 24px;
}

.footer-inner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 40px;
}

.footer-logo {
  font-family: var(--font-serif);
  font-size: 1.125rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  display: block;
  margin-bottom: 8px;
}

.footer-tagline {
  font-size: 0.8125rem;
  color: rgba(255, 255, 255, 0.45);
}

.footer-nav {
  display: flex;
  gap: 28px;
  flex-wrap: wrap;
}

.footer-nav a {
  font-size: 0.875rem;
  color: rgba(255, 255, 255, 0.55);
  transition: var(--transition);
}

.footer-nav a:hover {
  color: var(--white);
}

.footer-bottom {
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding-top: 20px;
}

.copyright {
  font-size: 0.8125rem;
  color: rgba(255, 255, 255, 0.35);
}

@media (max-width: 768px) {
  .footer-inner {
    flex-direction: column;
    gap: 28px;
  }

  .footer-nav {
    gap: 16px;
  }
}
</style>
