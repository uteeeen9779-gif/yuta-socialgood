---
const beliefs = [
  {
    num: '01',
    img: '/philosophy01.jpg',
    title: '地域の事業者さまと都市部の専門人材で、新たな価値を共創する',
    body: '地域には本物の商材・文化・物語があります。しかし、デジタルや戦略の専門知識と都市部とのネットワークが不足していることが多い。都市部の専門人材は高い技術と知見を持ちながらも、地域とつながる機会が限られています。この二つの力が交わるところに、新しい価値が生まれます。私はその橋渡し役として、地域の本物の魅力を全国・世界へ届ける土台をつくっていきます。',
  },
  {
    num: '02',
    img: '/philosophy02.jpg',
    title: '部分最適ではなく全体最適にこだわる',
    body: 'WEBもECも、売上をつくるためのコミュニケーションツールです。「サイトを作ること」がゴールではなく、「その後にどう売上へ繋げるか」が本質です。売上拡大・販路拡大という経営課題に対して、WEB/ECの構築にとどまらず、現場オペレーションの効率化、DX・AI活用、マーケティング戦略の立案・実行・分析まで——事業全体をグロースハックしていきます。',
  },
  {
    num: '03',
    img: '/philosophy03.jpg',
    title: '100年後も魅力ある地域を、魅力ある日本を。',
    body: '地域の文化と魅力は、正しく発信されなければ消えていきます。素晴らしい商材も、伝わらなければ存在しないのと同じ。小さくても、地方にあっても、本物の価値を持つ事業者が全国・世界に届く土台をつくること。その積み重ねが、100年後も魅力ある地域を、魅力ある日本をつくると信じています。その未来のために、私はデジタルを使い続けます。',
  },
];
---
<section class="philosophy" id="philosophy">
  <div class="container">

    <div class="phil-header">
      <p class="eyebrow">Philosophy</p>
      <h2 class="display-title">大切にしていること</h2>
      <p class="section-lead">
        地域の魅力を、全国へ、世界へ、100年先へ。<br />
        この信念が、すべての仕事の出発点です。
      </p>
    </div>

    <div class="beliefs-grid">
      {beliefs.map((b) => (
        <div class="belief-card">
          <div class="belief-img-wrap">
            <img src={b.img} alt={b.title} loading="lazy" class="belief-img" />
            <span class="belief-num-badge">{b.num}</span>
          </div>
          <div class="belief-body">
            <h3 class="belief-title">{b.title}</h3>
            <p class="belief-text">{b.body}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
.philosophy {
  background: var(--bg-soft);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.phil-header {
  max-width: 600px;
  margin-bottom: 56px;
}

/* ── Grid ── */
.beliefs-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.belief-card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: var(--transition);
}

.belief-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
  border-color: transparent;
}

/* ── Image ── */
.belief-img-wrap {
  position: relative;
  aspect-ratio: 4 / 3;
  overflow: hidden;
  flex-shrink: 0;
}

.belief-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.belief-card:hover .belief-img {
  transform: scale(1.04);
}

.belief-num-badge {
  position: absolute;
  top: 16px;
  left: 16px;
  font-family: var(--font-mono);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--white);
  background: var(--accent);
  padding: 5px 12px;
  border-radius: 20px;
}

/* ── Content ── */
.belief-body {
  padding: 28px 28px 32px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex: 1;
}

.belief-title {
  font-family: var(--font-serif);
  font-size: 1.0625rem;
  font-weight: 600;
  color: var(--text);
  line-height: 1.5;
}

.belief-text {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.95;
}

@media (max-width: 1024px) {
  .beliefs-grid {
    grid-template-columns: 1fr;
    max-width: 560px;
  }
}
</style>
