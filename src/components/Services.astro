---
const services = [
  {
    num: '01',
    title: 'WEBサイト構築・運用',
    desc: '戦略設計からデザイン・実装・運用まで一貫対応。多言語・インバウンド対応のサイト構築も得意としています。',
    tags: ['Wix', 'WordPress', 'STUDIO', '多言語対応', 'インバウンド'],
  },
  {
    num: '02',
    title: 'ECサイト構築・運用',
    desc: '決済・在庫・マーケティング連携まで、売れる仕組みを構築。宿泊施設向けのOTA・予約システム連携も対応します。',
    tags: ['Shopify', 'Stores', 'BASE', 'Stripe', 'OTA連携'],
  },
  {
    num: '03',
    title: 'AI導入・業務改善支援',
    desc: '業務フローの可視化と改善設計、AI活用による業務効率化。現場が自走できる状態になるまで伴走します。',
    tags: ['業務フロー設計', '自動化', '定着支援'],
    badge: '対応拡大中',
  },
];

const steps = [
  { label: 'Step 01', text: 'ヒアリング' },
  { label: 'Step 02', text: '現状診断' },
  { label: 'Step 03', text: '戦略立案' },
  { label: 'Step 04', text: '実装' },
  { label: 'Step 05', text: '運用' },
  { label: 'Step 06', text: '自走支援' },
];
---
<section class="services" id="services">
  <div class="container">

    <div class="svc-header">
      <p class="eyebrow">Services</p>
      <h2 class="display-title">できること</h2>
      <p class="section-lead">
        構築して終わりではなく、事業が動くまで。<br />
        戦略立案から実装・定着まで一貫して支援します。
      </p>
    </div>

    <div class="svc-grid">
      {services.map((s) => (
        <div class="svc-card">
          <div class="svc-top">
            <span class="svc-num">{s.num}</span>
            {s.badge && <span class="svc-badge">{s.badge}</span>}
          </div>
          <h3 class="svc-title">{s.title}</h3>
          <p class="svc-desc">{s.desc}</p>
          <div class="svc-tags">
            {s.tags.map((t) => (
              <span class="chip">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="process-section">
      <p class="process-label eyebrow">Process</p>
      <div class="process-track">
        {steps.map((step, i) => (
          <div class="process-step">
            <div class="step-inner">
              <span class="step-label">{step.label}</span>
              <span class="step-text">{step.text}</span>
            </div>
            {i < steps.length - 1 && (
              <div class="step-connector">
                <svg width="36" height="16" viewBox="0 0 36 16" fill="none">
                  <line x1="0" y1="8" x2="26" y2="8" stroke="#1B5C3E" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.4"/>
                  <path d="M26 4 L34 8 L26 12 Z" fill="#1B5C3E" opacity="0.5"/>
                </svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <p class="svc-note">
      ※ その他：宿泊施設向け予約システム・OTA連携、公式LINE構築、SNS運用、グロースハックなども対応しています。
    </p>

  </div>
</section>

<style>
.svc-header {
  max-width: 600px;
  margin-bottom: 56px;
}

.svc-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-bottom: 48px;
}

.svc-card {
  background: var(--bg-soft);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 40px 36px;
  display: flex;
  flex-direction: column;
  gap: 0;
  transition: var(--transition);
  position: relative;
  overflow: hidden;
}

.svc-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--accent);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s ease;
}

.svc-card:hover::before { transform: scaleX(1); }

.svc-card:hover {
  background: var(--bg);
  box-shadow: var(--shadow);
  border-color: var(--border-mid);
}

.svc-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
}

.svc-num {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 0.1em;
}

.svc-badge {
  font-family: var(--font-mono);
  font-size: 0.625rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--accent);
  border: 1px solid rgba(27,92,62,0.3);
  background: var(--accent-pale);
  padding: 3px 8px;
  border-radius: 20px;
}

.svc-title {
  font-family: var(--font-serif);
  font-size: 1.1875rem;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 14px;
  line-height: 1.4;
}

.svc-desc {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.85;
  margin-bottom: 24px;
  flex: 1;
}

.svc-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

/* ── Process ── */
.process-section {
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 36px 40px;
  margin-bottom: 20px;
}

.process-label {
  margin-bottom: 24px;
}

.process-track {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0;
}

.process-step {
  display: flex;
  align-items: center;
  gap: 0;
}

.step-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 0 8px;
}

.step-label {
  font-family: var(--font-mono);
  font-size: 0.625rem;
  color: var(--accent);
  letter-spacing: 0.1em;
  opacity: 0.7;
}

.step-text {
  font-size: 0.9375rem;
  font-weight: 700;
  color: var(--text);
}

.step-connector {
  margin: 0 4px;
  flex-shrink: 0;
  margin-bottom: 2px;
}

.svc-note {
  font-size: 0.8125rem;
  color: var(--text-light);
  line-height: 1.7;
}

@media (max-width: 1024px) {
  .svc-grid {
    grid-template-columns: 1fr;
    max-width: 540px;
  }
  .process-section { padding: 28px 24px; }
}

@media (max-width: 640px) {
  .process-track { gap: 16px; }
  .step-connector { display: none; }
}
</style>
