---
const works = [
  {
    category: '食品販売',
    region: '中国地方',
    desc: 'WEBサイト・EC運用、マーケティング支援',
    tags: ['WEB運用', 'EC', 'マーケティング'],
  },
  {
    category: '一棟貸し古民家',
    region: '中国地方',
    desc: 'WEBサイト構築、予約システム、多言語対応',
    tags: ['WEB構築', '予約システム', '多言語'],
  },
  {
    category: '建築家',
    region: '千葉',
    desc: '多言語WEBサイト構築、海外向け集客支援',
    tags: ['多言語', '海外集客', 'WEB構築'],
  },
  {
    category: '古民家',
    region: '千葉',
    desc: 'WEBサイト構築',
    tags: ['WEB構築'],
  },
  {
    category: 'クラフトビール醸造所',
    region: '千葉',
    desc: 'WEBサイト構築・運用、クリエイティブ制作、マーケティング支援',
    tags: ['WEB', 'クリエイティブ', 'マーケティング'],
  },
  {
    category: '日本工芸画廊',
    region: '東京',
    desc: 'WEB／EC一体型サイト構築・運用、マーケティング支援',
    tags: ['WEB/EC統合', 'EC', 'マーケティング'],
  },
];
---
<section class="works" id="works">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Works</span>
      <h2 class="section-title">実績</h2>
      <p class="section-subtitle">
        食品・宿泊・建築・工芸・飲食など、多業種の中小企業を支援してきました。
      </p>
    </div>
    <div class="works-grid">
      {works.map((w) => (
        <div class="work-card">
          <div class="work-header">
            <h3 class="work-category">{w.category}</h3>
            <span class="work-region">{w.region}</span>
          </div>
          <p class="work-desc">{w.desc}</p>
          <div class="work-tags">
            {w.tags.map((t) => (
              <span class="work-tag">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.works {
  background: var(--bg-alt);
}

.works-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.work-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: var(--transition);
}

.work-card:hover {
  box-shadow: var(--shadow);
  border-color: var(--accent-light);
  transform: translateY(-2px);
}

.work-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
}

.work-category {
  font-family: var(--font-serif);
  font-size: 1rem;
  font-weight: 600;
  color: var(--text);
}

.work-region {
  display: inline-block;
  font-size: 0.7rem;
  color: var(--text-light);
  background: var(--bg-alt);
  padding: 3px 8px;
  border-radius: 4px;
  white-space: nowrap;
  flex-shrink: 0;
}

.work-desc {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.75;
  flex: 1;
}

.work-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.work-tag {
  font-size: 0.7rem;
  color: var(--accent);
  background: var(--accent-light);
  padding: 3px 8px;
  border-radius: 4px;
  font-weight: 500;
}

@media (max-width: 1024px) {
  .works-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 640px) {
  .works-grid {
    grid-template-columns: 1fr;
  }
}
</style>
