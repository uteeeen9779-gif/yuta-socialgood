---
---
<section class="hero" id="home">
  <div class="hero-bg">
    <img src="/kv-pattern.png" alt="" class="hero-kv" aria-hidden="true" />
  </div>

  <div class="container">
    <div class="hero-inner">

      <div class="hero-text">
        <p class="eyebrow">Web Director</p>
        <h1 class="hero-title">
          地域とつなぐ、<br />世界とつなぐ。
        </h1>
        <p class="hero-sub">地域事業者さまのデジタル参謀（CMO）</p>
        <p class="hero-desc">
          上場企業にて経営戦略業務に従事しながら、個人事業主として
          地域の中小企業さまの商材を全国・世界に発信していく
          デジタル支援を複業で行っています。
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn-primary">まずは相談する →</a>
          <a href="#works" class="btn-outline">実績を見る</a>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-photo-wrap">
          <img src="/profile.jpg" alt="YU_TABI" class="hero-photo" />
        </div>
      </div>

    </div>

    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-num">6<small>+</small></span>
        <span class="stat-text">支援実績</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat-item">
        <span class="stat-num">3</span>
        <span class="stat-text">コアサービス</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat-item">
        <span class="stat-num">10<small>+</small></span>
        <span class="stat-text">対応ツール</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat-item">
        <span class="stat-num">4<small>年</small></span>
        <span class="stat-text">支援経験</span>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding-top: 68px;
  position: relative;
  overflow: hidden;
  background: var(--bg);
}

/* ── KV background ── */
.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.hero-kv {
  position: absolute;
  top: 0;
  right: 0;
  height: 100%;
  width: 55%;
  object-fit: cover;
  object-position: center;
  opacity: 0.9;
}

.container {
  position: relative;
  z-index: 1;
}

/* ── Layout ── */
.hero-inner {
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 64px;
  align-items: center;
  padding: 80px 0 56px;
}

/* ── Text ── */
.hero-title {
  font-family: var(--font-serif);
  font-size: clamp(3rem, 6.5vw, 5.25rem);
  font-weight: 600;
  line-height: 1.18;
  letter-spacing: -0.02em;
  color: var(--text);
  margin-bottom: 20px;
}

.hero-sub {
  font-size: 1.0625rem;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 14px;
  letter-spacing: 0.01em;
}

.hero-desc {
  font-size: 0.9375rem;
  color: var(--text-muted);
  line-height: 1.85;
  margin-bottom: 40px;
  max-width: 480px;
}

.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

/* ── Photo ── */
.hero-visual {
  position: relative;
  z-index: 2;
}

.hero-photo-wrap {
  border-radius: var(--radius-lg);
  overflow: hidden;
  aspect-ratio: 4 / 5;
  box-shadow: var(--shadow-lg);
}

.hero-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  transition: transform 0.6s ease;
}

.hero-photo-wrap:hover .hero-photo {
  transform: scale(1.03);
}

/* ── Stats bar ── */
.hero-stats {
  display: flex;
  align-items: center;
  border-top: 1px solid var(--border);
  padding: 40px 0;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(4px);
  border-radius: var(--radius);
  padding: 32px 40px;
  margin-bottom: 16px;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 0 32px;
}

.stat-item:first-child { padding-left: 0; }

.stat-num {
  font-family: var(--font-serif);
  font-size: 2.25rem;
  font-weight: 600;
  line-height: 1;
  color: var(--text);
}

.stat-num small {
  font-size: 1.1rem;
  color: var(--accent);
  font-weight: 500;
}

.stat-text {
  font-size: 0.75rem;
  color: var(--text-light);
  letter-spacing: 0.06em;
}

.stat-sep {
  width: 1px;
  height: 40px;
  background: var(--border);
  flex-shrink: 0;
}

@media (max-width: 1024px) {
  .hero-inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .hero-visual { max-width: 360px; }
  .hero-kv { width: 100%; opacity: 0.15; }
  .stat-item { padding: 0 20px; }
}

@media (max-width: 640px) {
  .hero-stats {
    flex-wrap: wrap;
    gap: 24px;
    padding: 24px;
  }
  .stat-sep { display: none; }
  .stat-item {
    flex: none;
    padding: 0;
    width: calc(50% - 12px);
  }
}
</style>
